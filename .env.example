# DashScope (Alibaba Bailian) — LLM, Embedding, Rerank
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Models
RAG_LLM_MODEL=qwen-plus
RAG_EMBEDDING_MODEL=text-embedding-v3
RAG_EMBEDDING_DIM=1024

# Elasticsearch
ES_HOST=http://localhost:9200
ES_USER=elastic
ES_PASSWORD=infini_rag_flow

# HuggingFace mirror (for downloading OCR models in mainland China)
HF_ENDPOINT=https://hf-mirror.com

# Storage
RAG_STORAGE_DIR=./storage
